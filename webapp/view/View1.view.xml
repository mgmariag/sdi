<mvc:View controllerName="disertatie.controller.View1"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:viz="sap.viz.ui5.controls"
    xmlns:viz.data="sap.viz.ui5.data"
    xmlns:viz.feeds="sap.viz.ui5.controls.common.feeds">
    <Page id="page1" title="Digital Twin (DT) for Irrigation Systems - Experiments">
        <VBox id="v1" class="experimentPage">
            <Text id="helloMessage" text="{/helloMessage}" class="experimentHeadline" />
            <MessageStrip id="rangeDataAlert" text="{/rangeAlert/text}" type="Warning" visible="{/rangeAlert/visible}" showIcon="true" showCloseButton="true" class="sapUiSmallMarginTop" />
            <Panel id="settingsPanel" headerText="Parameters" expandable="false" class="sapUiSmallMarginTop experimentPanel">
                <VBox>
                    <HBox alignItems="Center" justifyContent="SpaceBetween" class="experimentControlRow">
                        <VBox>
                            <Label text="Start date" labelFor="startDateInput" />
                            <DatePicker id="startDateInput" value="{/experimentSettings/start_date}" valueFormat="yyyy-MM-dd" displayFormat="yyyy-MM-dd" width="9rem" />
                        </VBox>
                        <VBox>
                            <Label text="End date" labelFor="endDateInput" />
                            <DatePicker id="endDateInput" value="{/experimentSettings/end_date}" valueFormat="yyyy-MM-dd" displayFormat="yyyy-MM-dd" width="9rem" />
                        </VBox>
                        <VBox>
                            <Label text="Sample interval (hours)" labelFor="sampleIntervalInput" />
                            <Input id="sampleIntervalInput" value="{/samplingSettings/sample_interval_hours}" type="Number" width="8rem" />
                        </VBox>
                        <VBox>
                            <Label text="Sensors" labelFor="sensorCountInput" />
                            <Input id="sensorCountInput" value="{/sensorSettings/sensor_count}" type="Number" width="6rem" showValueHelp="true" valueHelpRequest="onSensorLocationHelp" />
                        </VBox>
                        <HBox class="experimentButtonGroup" alignItems="Center" justifyContent="SpaceBetween">
                            <Button text="Baseline" press="onRunExperiment" type="Accept" class="experimentButton baselineButton" />
                            <Button text="Sampling" press="onRunSamplingExperiment" type="Emphasized" class="experimentButton samplingButton" />
                            <Button text="ANFIS-GA" press="onRunAnfisExperiment" type="Accept" class="experimentButton anfisButton" />
                        </HBox>
                    </HBox>
                </VBox>
            </Panel>

            <Text id="activeText" class="sapUiSmallMarginTop" text="{= ${/activeExperiment} === 'baseline' ? 'Baseline results' : ${/activeExperiment} === 'sampling' ? 'Sampling experiment results' : ${/activeExperiment} === 'anfis' ? 'ANFIS decision experiment results' : 'Choose an experiment to run from the buttons above.' }" />

            <Panel id="baselinePanel" headerText="Baseline" expandable="false" visible="{= ${/activeExperiment} === 'baseline'}" class="sapUiSmallMarginTop baselinePanel experimentPanel">
                <VBox class="busyWrapper" visible="{/isLoading}">
                    <BusyIndicator visible="{/isLoading}" text="Running daily irrigation experiment..." />
                </VBox>
                <VBox class="summarySection">
                    <Text text="{= 'Days analyzed: ' + ${/summary/daysAnalyzed}}" />
                    <Text text="{= 'Pots analyzed: ' + ${/summary/potsAnalyzed}}" />
                    <Text text="{= 'Irrigation events: ' + ${/summary/irrigationEvents}}" />
                    <Text text="{= 'Irrigation decisions: ' + ${/summary/irrigationDecisions}}" />
                    <Text text="{= 'Total water usage (L): ' + ${/summary/totalWaterUsage}}" />
                    <Text text="{= 'Average daily water usage (L): ' + ${/summary/averageDailyWaterUsage}}" />
                    <Text text="{= 'Emergency dryness alerts: ' + ${/summary/emergencyAlerts}}" />
                </VBox>
                <viz:VizFrame id="baselineChart" uiConfig="{applicationSet:'fiori'}" vizType="line" height="400px" width="100%" renderComplete=".onChartRenderComplete">
                    <viz:dataset>
                        <viz.data:FlattenedDataset data="{/baselineChartEntries}">
                            <viz.data:dimensions>
                                <viz.data:DimensionDefinition name="Date/Time" value="{chart_label}" />
                            </viz.data:dimensions>
                            <viz.data:measures>
                                <viz.data:MeasureDefinition name="Average Moisture" value="{average_moisture}" />
                                <viz.data:MeasureDefinition name="Water Usage (L)" value="{water_usage_chart}" />
                            </viz.data:measures>
                        </viz.data:FlattenedDataset>
                    </viz:dataset>
                    <viz:feeds>
                        <viz.feeds:FeedItem uid="valueAxis" type="Measure" values="Average Moisture,Water Usage (L)" />
                        <viz.feeds:FeedItem uid="categoryAxis" type="Dimension" values="Date/Time" />
                    </viz:feeds>
                </viz:VizFrame>
                <IconTabBar id="baselineDataTabs" class="experimentDataTabs">
                    <items>
                        <IconTabFilter id="baselineExperimentDataTab" text="Experiment data">
                <Table id="baselineDataTable" class="experimentDataTable" items="{/baselineEntries}" growing="true" growingThreshold="20" growingScrollToLoad="false">
                    <headerToolbar>
                        <Toolbar id="baselineDataToolbar">
                            <Title id="baselineDataTitle" text="Experiment data" />
                        </Toolbar>
                    </headerToolbar>
                    <columns>
                        <Column id="baselineStepCol"><Text id="baselineStepHeader" text="Date" /></Column>
                        <Column id="baselineMoistureCol"><Text id="baselineMoistureHeader" text="Avg Moisture (%)" /></Column>
                        <Column id="baselineTempCol"><Text id="baselineTempHeader" text="Max Temp" /></Column>
                        <Column id="baselineHumidityCol"><Text id="baselineHumidityHeader" text="Avg Humidity" /></Column>
                        <Column id="baselineRainCol"><Text id="baselineRainHeader" text="Rain (mm)" /></Column>
                        <Column id="baselineIrrigationCol"><Text id="baselineIrrigationHeader" text="Events" /></Column>
                        <Column id="baselineWaterCol"><Text id="baselineWaterHeader" text="Water (L)" /></Column>
                        <Column id="baselineAlertsCol"><Text id="baselineAlertsHeader" text="Alerts" /></Column>
                    </columns>
                    <items>
                        <ColumnListItem id="baselineDataRow">
                            <cells>
                                <Text id="baselineStepCell" text="{day_label}" />
                                <Text id="baselineMoistureCell" text="{average_moisture}" />
                                <Text id="baselineTempCell" text="{max_temperature}" />
                                <Text id="baselineHumidityCell" text="{humidity}" />
                                <Text id="baselineRainCell" text="{rain_amount}" />
                                <Text id="baselineIrrigationCell" text="{irrigation_events}" />
                                <Text id="baselineWaterCell" text="{water_usage_l}" />
                                <Text id="baselineAlertsCell" text="{alerts}" />
                            </cells>
                        </ColumnListItem>
                    </items>
                </Table>
                        </IconTabFilter>
                        <IconTabFilter id="baselinePotsTab" text="Pots">
                            <Table id="baselinePotsTable" class="experimentDataTable" items="{/baselinePots}" growing="true" growingThreshold="20" growingScrollToLoad="false">
                                <columns>
                                    <Column id="baselinePotCodeCol"><Text id="baselinePotCodeHeader" text="Code" /></Column>
                                    <Column id="baselinePotLabelCol"><Text id="baselinePotLabelHeader" text="Pot" /></Column>
                                    <Column id="baselinePotSizeCol"><Text id="baselinePotSizeHeader" text="Size" /></Column>
                                    <Column id="baselinePotPlantCol"><Text id="baselinePotPlantHeader" text="Plant" /></Column>
                                    <Column id="baselinePotLocationCol"><Text id="baselinePotLocationHeader" text="Location" /></Column>
                                    <Column id="baselinePotSunCol"><Text id="baselinePotSunHeader" text="Sun" /></Column>
                                    <Column id="baselinePotFlowCol"><Text id="baselinePotFlowHeader" text="Flow ml/min" /></Column>
                                    <Column id="baselinePotTargetCol"><Text id="baselinePotTargetHeader" text="Target %" /></Column>
                                </columns>
                                <items>
                                    <ColumnListItem id="baselinePotRow">
                                        <cells>
                                            <Text id="baselinePotCodeCell" text="{pot_code}" />
                                            <Text id="baselinePotLabelCell" text="{label}" />
                                            <Text id="baselinePotSizeCell" text="{= ${small_subtype} ? ${size_class} + ' ' + ${small_subtype} : ${size_class}}" />
                                            <Text id="baselinePotPlantCell" text="{plant_type_label}" />
                                            <Text id="baselinePotLocationCell" text="{default_location}" />
                                            <Text id="baselinePotSunCell" text="{sun_exposure}" />
                                            <Text id="baselinePotFlowCell" text="{drip_flow_ml_min}" />
                                            <Text id="baselinePotTargetCell" text="{moisture_target_pct}" />
                                        </cells>
                                    </ColumnListItem>
                                </items>
                            </Table>
                        </IconTabFilter>
                    </items>
                </IconTabBar>
            </Panel>

            <Panel id="samplingPanel" headerText="Sampling Optimization" expandable="false" visible="{= ${/activeExperiment} === 'sampling'}" class="sapUiSmallMarginTop samplingPanel experimentPanel">
                <VBox class="busyWrapper" visible="{/isSamplingLoading}">
                    <BusyIndicator visible="{/isSamplingLoading}" text="Running sampling experiment..." />
                </VBox>
                <VBox class="summarySection">
                    <Text text="{= 'Days analyzed: ' + ${/samplingSummary/daysAnalyzed}}" />
                    <Text text="{= 'Sample interval (hours): ' + ${/samplingSummary/sample_interval_hours}}" />
                    <Text text="{= 'Accuracy: ' + ${/samplingSummary/accuracy_percent} + '%'}" />
                    <Text text="{= 'Mismatch days: ' + ${/samplingSummary/mismatch_days}}" />
                    <Text text="{= 'Baseline water usage (L): ' + ${/samplingSummary/baseline_total_water_usage_l}}" />
                    <Text text="{= 'Sparse water usage (L): ' + ${/samplingSummary/sparse_total_water_usage_l}}" />
                    <Text text="{= 'Baseline irrigation events: ' + ${/samplingSummary/baseline_irrigation_event_count}}" />
                    <Text text="{= 'Sparse irrigation events: ' + ${/samplingSummary/sparse_irrigation_event_count}}" />
                </VBox>
                <viz:VizFrame id="samplingChart" uiConfig="{applicationSet:'fiori'}" vizType="line" height="400px" width="100%" renderComplete=".onChartRenderComplete">
                    <viz:dataset>
                        <viz.data:FlattenedDataset data="{/samplingChartEntries}">
                            <viz.data:dimensions>
                                <viz.data:DimensionDefinition name="Date/Time" value="{chart_label}" />
                            </viz.data:dimensions>
                            <viz.data:measures>
                                <viz.data:MeasureDefinition name="Baseline Moisture" value="{baseline_moisture}" />
                                <viz.data:MeasureDefinition name="Sparse Moisture" value="{sparse_moisture}" />
                                <viz.data:MeasureDefinition name="Sparse Water Usage (L)" value="{sparse_water_usage_chart}" />
                            </viz.data:measures>
                        </viz.data:FlattenedDataset>
                    </viz:dataset>
                    <viz:feeds>
                        <viz.feeds:FeedItem uid="valueAxis" type="Measure" values="Baseline Moisture,Sparse Moisture,Sparse Water Usage (L)" />
                        <viz.feeds:FeedItem uid="categoryAxis" type="Dimension" values="Date/Time" />
                    </viz:feeds>
                </viz:VizFrame>
                <IconTabBar id="samplingDataTabs" class="experimentDataTabs">
                    <items>
                        <IconTabFilter id="samplingExperimentDataTab" text="Experiment data">
                <Table id="samplingDataTable" class="experimentDataTable" items="{/samplingEntries}" growing="true" growingThreshold="20" growingScrollToLoad="false">
                    <headerToolbar>
                        <Toolbar id="samplingDataToolbar">
                            <Title id="samplingDataTitle" text="Experiment data" />
                        </Toolbar>
                    </headerToolbar>
                    <columns>
                        <Column id="samplingStepCol"><Text id="samplingStepHeader" text="Date" /></Column>
                        <Column id="samplingBaselineMoistureCol"><Text id="samplingBaselineMoistureHeader" text="Baseline Moisture (%)" /></Column>
                        <Column id="samplingSparseMoistureCol"><Text id="samplingSparseMoistureHeader" text="Sparse Moisture (%)" /></Column>
                        <Column id="samplingRainCol"><Text id="samplingRainHeader" text="Rain (mm)" /></Column>
                        <Column id="samplingBaselineIrrigationCol"><Text id="samplingBaselineIrrigationHeader" text="Baseline Events" /></Column>
                        <Column id="samplingSparseIrrigationCol"><Text id="samplingSparseIrrigationHeader" text="Sparse Events" /></Column>
                        <Column id="samplingSparseWaterCol"><Text id="samplingSparseWaterHeader" text="Sparse Water (L)" /></Column>
                    </columns>
                    <items>
                        <ColumnListItem id="samplingDataRow">
                            <cells>
                                <Text id="samplingStepCell" text="{day_label}" />
                                <Text id="samplingBaselineMoistureCell" text="{baseline_moisture}" />
                                <Text id="samplingSparseMoistureCell" text="{sparse_moisture}" />
                                <Text id="samplingRainCell" text="{rain_amount}" />
                                <Text id="samplingBaselineIrrigationCell" text="{baseline_irrigation_events}" />
                                <Text id="samplingSparseIrrigationCell" text="{sparse_irrigation_events}" />
                                <Text id="samplingSparseWaterCell" text="{sparse_water_usage_l}" />
                            </cells>
                        </ColumnListItem>
                    </items>
                </Table>
                        </IconTabFilter>
                        <IconTabFilter id="samplingPotsTab" text="Pots">
                            <Table id="samplingPotsTable" class="experimentDataTable" items="{/samplingPots}" growing="true" growingThreshold="20" growingScrollToLoad="false">
                                <columns>
                                    <Column id="samplingPotCodeCol"><Text id="samplingPotCodeHeader" text="Code" /></Column>
                                    <Column id="samplingPotLabelCol"><Text id="samplingPotLabelHeader" text="Pot" /></Column>
                                    <Column id="samplingPotSizeCol"><Text id="samplingPotSizeHeader" text="Size" /></Column>
                                    <Column id="samplingPotPlantCol"><Text id="samplingPotPlantHeader" text="Plant" /></Column>
                                    <Column id="samplingPotLocationCol"><Text id="samplingPotLocationHeader" text="Location" /></Column>
                                    <Column id="samplingPotSunCol"><Text id="samplingPotSunHeader" text="Sun" /></Column>
                                    <Column id="samplingPotFlowCol"><Text id="samplingPotFlowHeader" text="Flow ml/min" /></Column>
                                    <Column id="samplingPotTargetCol"><Text id="samplingPotTargetHeader" text="Target %" /></Column>
                                </columns>
                                <items>
                                    <ColumnListItem id="samplingPotRow">
                                        <cells>
                                            <Text id="samplingPotCodeCell" text="{pot_code}" />
                                            <Text id="samplingPotLabelCell" text="{label}" />
                                            <Text id="samplingPotSizeCell" text="{= ${small_subtype} ? ${size_class} + ' ' + ${small_subtype} : ${size_class}}" />
                                            <Text id="samplingPotPlantCell" text="{plant_type_label}" />
                                            <Text id="samplingPotLocationCell" text="{default_location}" />
                                            <Text id="samplingPotSunCell" text="{sun_exposure}" />
                                            <Text id="samplingPotFlowCell" text="{drip_flow_ml_min}" />
                                            <Text id="samplingPotTargetCell" text="{moisture_target_pct}" />
                                        </cells>
                                    </ColumnListItem>
                                </items>
                            </Table>
                        </IconTabFilter>
                    </items>
                </IconTabBar>
            </Panel>

            <Panel id="anfisPanel" headerText="ANFIS Intelligent Control" expandable="false" visible="{= ${/activeExperiment} === 'anfis'}" class="sapUiSmallMarginTop anfisPanel experimentPanel">
                <VBox class="busyWrapper" visible="{/isAnfisLoading}">
                    <BusyIndicator visible="{/isAnfisLoading}" text="Running ANFIS experiment..." />
                </VBox>
                <HBox class="summarySection summaryColumns" width="100%" justifyContent="SpaceBetween">
                    <VBox class="summaryColumn">
                        <Text text="{= 'Days analyzed: ' + ${/anfisSummary/daysAnalyzed}}" />
                        <Text text="{= 'Baseline irrigation days: ' + ${/anfisSummary/baseline_irrigation_days}}" />
                        <Text text="{= 'ANFIS irrigation days: ' + ${/anfisSummary/anfis_irrigation_days}}" />
                        <Text text="{= 'Baseline irrigation events: ' + ${/anfisSummary/baseline_irrigation_event_count}}" />
                        <Text text="{= 'ANFIS irrigation events: ' + ${/anfisSummary/anfis_irrigation_event_count}}" />
                        <Text text="{= 'Baseline water usage (L): ' + ${/anfisSummary/baseline_total_water_usage_l}}" />
                        <Text text="{= 'ANFIS water usage (L): ' + ${/anfisSummary/anfis_total_water_usage_l}}" />
                        <Text text="{= ''}" />
                        <Text text="{= 'Test accuracy: ' + ${/anfisSummary/test_accuracy_percent} + '%'}" />
                        <Text text="{= 'Execution time: ' + ${/anfisSummary/execution_time_seconds} + ' s'}" />
                    </VBox>
                    <VBox class="summaryColumn probabilitySummaryColumn">
                        <Text text="{= 'Predicted probability mean: ' + ${/anfisSummary/predicted_probability_mean}}" />
                        <Text text="{= 'Predicted probability min: ' + ${/anfisSummary/predicted_probability_min}}" />
                        <Text text="{= 'Predicted probability max: ' + ${/anfisSummary/predicted_probability_max}}" />
                    </VBox>
                </HBox>
                <viz:VizFrame id="anfisChart" uiConfig="{applicationSet:'fiori'}" vizType="line" height="400px" width="100%" renderComplete=".onChartRenderComplete">
                    <viz:dataset>
                        <viz.data:FlattenedDataset data="{/anfisChartEntries}">
                            <viz.data:dimensions>
                                <viz.data:DimensionDefinition name="Date/Time" value="{chart_label}" />
                            </viz.data:dimensions>
                            <viz.data:measures>
                                <viz.data:MeasureDefinition name="ANFIS Moisture" value="{anfis_moisture}" />
                                <viz.data:MeasureDefinition name="Predicted Probability" value="{predicted_probability_percent}" />
                                <viz.data:MeasureDefinition name="ANFIS Water Usage (L)" value="{anfis_water_usage_chart}" />
                            </viz.data:measures>
                        </viz.data:FlattenedDataset>
                    </viz:dataset>
                    <viz:feeds>
                        <viz.feeds:FeedItem uid="valueAxis" type="Measure" values="ANFIS Moisture,Predicted Probability,ANFIS Water Usage (L)" />
                        <viz.feeds:FeedItem uid="categoryAxis" type="Dimension" values="Date/Time" />
                    </viz:feeds>
                </viz:VizFrame>
                <IconTabBar id="anfisDataTabs" class="experimentDataTabs">
                    <items>
                        <IconTabFilter id="anfisExperimentDataTab" text="Experiment data">
                <Table id="anfisDataTable" class="experimentDataTable" items="{/anfisEntries}" growing="true" growingThreshold="20" growingScrollToLoad="false">
                    <headerToolbar>
                        <Toolbar id="anfisDataToolbar">
                            <Title id="anfisDataTitle" text="Experiment data" />
                        </Toolbar>
                    </headerToolbar>
                    <columns>
                        <Column id="anfisStepCol"><Text id="anfisStepHeader" text="Date" /></Column>
                        <Column id="anfisMoistureCol"><Text id="anfisMoistureHeader" text="ANFIS Moisture (%)" /></Column>
                        <Column id="anfisProbabilityCol"><Text id="anfisProbabilityHeader" text="Predicted Probability" /></Column>
                        <Column id="anfisCategoryCol"><Text id="anfisCategoryHeader" text="Category" /></Column>
                        <Column id="anfisBaselineIrrigationCol"><Text id="anfisBaselineIrrigationHeader" text="Baseline Events" /></Column>
                        <Column id="anfisIrrigationCol"><Text id="anfisIrrigationHeader" text="ANFIS Events" /></Column>
                        <Column id="anfisWaterCol"><Text id="anfisWaterHeader" text="ANFIS Water (L)" /></Column>
                    </columns>
                    <items>
                        <ColumnListItem id="anfisDataRow">
                            <cells>
                                <Text id="anfisStepCell" text="{day_label}" />
                                <Text id="anfisMoistureCell" text="{anfis_moisture}" />
                                <Text id="anfisProbabilityCell" text="{predicted_probability_percent}" />
                                <Text id="anfisCategoryCell" text="{predicted_category}" />
                                <Text id="anfisBaselineIrrigationCell" text="{baseline_irrigation_events}" />
                                <Text id="anfisIrrigationCell" text="{anfis_irrigation_events}" />
                                <Text id="anfisWaterCell" text="{anfis_water_usage_l}" />
                            </cells>
                        </ColumnListItem>
                    </items>
                </Table>
                        </IconTabFilter>
                        <IconTabFilter id="anfisPotsTab" text="Pots">
                            <Table id="anfisPotsTable" class="experimentDataTable" items="{/anfisPots}" growing="true" growingThreshold="20" growingScrollToLoad="false">
                                <columns>
                                    <Column id="anfisPotCodeCol"><Text id="anfisPotCodeHeader" text="Code" /></Column>
                                    <Column id="anfisPotLabelCol"><Text id="anfisPotLabelHeader" text="Pot" /></Column>
                                    <Column id="anfisPotSizeCol"><Text id="anfisPotSizeHeader" text="Size" /></Column>
                                    <Column id="anfisPotPlantCol"><Text id="anfisPotPlantHeader" text="Plant" /></Column>
                                    <Column id="anfisPotLocationCol"><Text id="anfisPotLocationHeader" text="Location" /></Column>
                                    <Column id="anfisPotSunCol"><Text id="anfisPotSunHeader" text="Sun" /></Column>
                                    <Column id="anfisPotFlowCol"><Text id="anfisPotFlowHeader" text="Flow ml/min" /></Column>
                                    <Column id="anfisPotTargetCol"><Text id="anfisPotTargetHeader" text="Target %" /></Column>
                                </columns>
                                <items>
                                    <ColumnListItem id="anfisPotRow">
                                        <cells>
                                            <Text id="anfisPotCodeCell" text="{pot_code}" />
                                            <Text id="anfisPotLabelCell" text="{label}" />
                                            <Text id="anfisPotSizeCell" text="{= ${small_subtype} ? ${size_class} + ' ' + ${small_subtype} : ${size_class}}" />
                                            <Text id="anfisPotPlantCell" text="{plant_type_label}" />
                                            <Text id="anfisPotLocationCell" text="{default_location}" />
                                            <Text id="anfisPotSunCell" text="{sun_exposure}" />
                                            <Text id="anfisPotFlowCell" text="{drip_flow_ml_min}" />
                                            <Text id="anfisPotTargetCell" text="{moisture_target_pct}" />
                                        </cells>
                                    </ColumnListItem>
                                </items>
                            </Table>
                        </IconTabFilter>
                    </items>
                </IconTabBar>
            </Panel>
        </VBox>
    </Page>
</mvc:View>
