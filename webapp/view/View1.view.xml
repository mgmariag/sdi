<mvc:View controllerName="disertatie.controller.View1"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:core="sap.ui.core"
    xmlns="sap.m"
    xmlns:viz="sap.viz.ui5.controls"
    xmlns:viz.data="sap.viz.ui5.data"
    xmlns:viz.feeds="sap.viz.ui5.controls.common.feeds">
    <Page id="page1" title="Digital Twin (DT) for Irrigation Systems - Experiments">
        <VBox id="v1" class="experimentPage">
            <Text id="helloMessage" text="{/helloMessage}" class="experimentHeadline" />
            <MessageStrip id="rangeDataAlert" text="{/rangeAlert/text}" type="Warning" visible="{/rangeAlert/visible}" showIcon="true" showCloseButton="true" class="sapUiSmallMarginTop" />
            <Panel id="settingsPanel" headerText="Parameters" expandable="false" class="sapUiSmallMarginTop experimentPanel">
                <VBox>
                    <HBox alignItems="Center" justifyContent="SpaceBetween" class="experimentControlRow">
                        <VBox>
                            <Label text="Start date" labelFor="startDateInput" />
                            <DatePicker id="startDateInput" value="{/experimentSettings/start_date}" valueFormat="yyyy-MM-dd" displayFormat="yyyy-MM-dd" width="9rem" change="onDateChange" />
                        </VBox>
                        <VBox>
                            <Label text="End date" labelFor="endDateInput" />
                            <DatePicker id="endDateInput" value="{/experimentSettings/end_date}" valueFormat="yyyy-MM-dd" displayFormat="yyyy-MM-dd" width="9rem" change="onDateChange" />
                        </VBox>
                        <VBox>
                            <Label text="Sensors" labelFor="sensorCountInput" />
                            <Input id="sensorCountInput" value="{/sensorSettings/sensor_count}" type="Number" width="6rem" showValueHelp="true" valueHelpRequest="onOpenSensorPlacement" />
                        </VBox>
                        <HBox class="experimentButtonGroup" alignItems="Center" justifyContent="SpaceBetween">
                            <VBox class="samplingParameterControl" width="8rem">
                                <Label text="Sample interval (h)" labelFor="sampleIntervalInput" />
                                <Input id="sampleIntervalInput" value="{/samplingSettings/sample_interval_hours}" type="Number" width="100%" />
                            </VBox>
                            <Button text="Sampling" press="onRunSampling" type="Emphasized" class="experimentButton samplingButton" />
                            <Button text="ANFIS-GA" press="onRunAnfis" type="Accept" class="experimentButton anfisButton" />
                            <Button text="Fuzzy DT" press="onRunFuzzyDt" type="Accept" class="experimentButton fuzzyButton" />
                        </HBox>
                    </HBox>
                </VBox>
            </Panel>

            <Panel id="experimentSummaryPanel" headerText="Experiment summary" expandable="true" expanded="true" visible="{= !!${/activeExperiment}}" class="sapUiSmallMarginTop experimentPanel experimentSummaryPanel">
                <core:HTML id="experimentSummaryCards" content="{/experimentSummaryCardsHtml}" sanitizeContent="false" />
            </Panel>

            <VBox id="overviewDashboard" visible="{= !${/activeExperiment}}" width="100%" class="overviewDashboard overviewWorkspace">
                <core:HTML id="overviewDefaultRail" content="{/overview/sideRailHtml}" sanitizeContent="false" />
            </VBox>

            <Text id="activeText" class="sapUiSmallMarginTop" visible="{= !!${/activeExperiment}}" text="{= ${/activeExperiment} === 'sampling' ? 'Sampling experiment results' : ${/activeExperiment} === 'anfis' ? 'ANFIS decision experiment results' : ${/activeExperiment} === 'fuzzy' ? 'Fuzzy DT recommendation results' : '' }" />

            <Panel id="samplingPanel" headerText="Sampling Optimization" expandable="false" visible="{= ${/activeExperiment} === 'sampling'}" class="sapUiSmallMarginTop samplingPanel experimentPanel">
                <VBox class="busyWrapper" visible="{/isSamplingLoading}">
                    <BusyIndicator visible="{/isSamplingLoading}" text="Running sampling experiment..." />
                </VBox>
                <HBox id="samplingChartRow" class="chartWithOverviewRail">
                    <VBox id="samplingChartColumn" class="chartMainColumn">
                        <viz:VizFrame id="samplingChart" uiConfig="{applicationSet:'fiori'}" vizType="combination" height="500px" width="100%" renderComplete=".onChartRenderComplete">
                            <viz:dataset>
                                <viz.data:FlattenedDataset data="{/samplingChartEntries}">
                                    <viz.data:dimensions>
                                        <viz.data:DimensionDefinition name="Date/Time" value="{chart_label}" />
                                    </viz.data:dimensions>
                                    <viz.data:measures>
                                        <viz.data:MeasureDefinition name="Baseline Moisture" value="{baseline_moisture}" />
                                        <viz.data:MeasureDefinition name="Baseline Water Usage (L)" value="{baseline_water_usage_chart}" />
                                        <viz.data:MeasureDefinition name="Sparse Moisture" value="{sparse_moisture}" />
                                        <viz.data:MeasureDefinition name="Sparse Water Usage (L)" value="{sparse_water_usage_chart}" />
                                        <viz.data:MeasureDefinition name="Max Temp (C)" value="{max_temperature}" />
                                        <viz.data:MeasureDefinition name="Rain (L/m2)" value="{rain_amount}" />
                                    </viz.data:measures>
                                </viz.data:FlattenedDataset>
                            </viz:dataset>
                            <viz:feeds>
                                <viz.feeds:FeedItem uid="valueAxis" type="Measure" values="Baseline Moisture,Baseline Water Usage (L),Sparse Moisture,Sparse Water Usage (L),Max Temp (C),Rain (L/m2)" />
                                <viz.feeds:FeedItem uid="categoryAxis" type="Dimension" values="Date/Time" />
                            </viz:feeds>
                        </viz:VizFrame>
                    </VBox>
                    <core:HTML
    id="samplingOverviewRail"
    content="{/overview/experimentSideRailHtml}"
    sanitizeContent="false" />
                </HBox>
                <IconTabBar id="samplingDataTabs" class="experimentDataTabs">
                    <items>
                        <IconTabFilter id="samplingExperimentDataTab" text="Experiment data">
                <Table id="samplingDataTable" class="experimentDataTable" items="{/samplingEntries}" growing="true" growingThreshold="20" growingScrollToLoad="false">
                    <headerToolbar>
                        <Toolbar id="samplingDataToolbar">
                            <Title id="samplingDataTitle" text="Experiment data" />
                        </Toolbar>
                    </headerToolbar>
                    <columns>
                        <Column id="samplingStepCol"><Text id="samplingStepHeader" text="Date" /></Column>
                        <Column id="samplingBaselineMoistureCol"><Text id="samplingBaselineMoistureHeader" text="Baseline Moisture (%)" /></Column>
                        <Column id="samplingSparseMoistureCol"><Text id="samplingSparseMoistureHeader" text="Sparse Moisture (%)" /></Column>
                        <Column id="samplingRainCol"><Text id="samplingRainHeader" text="Rain (L/m2)" /></Column>
                        <Column id="samplingBaselineIrrigationCol"><Text id="samplingBaselineIrrigationHeader" text="Baseline Windows" /></Column>
                        <Column id="samplingSparseIrrigationCol"><Text id="samplingSparseIrrigationHeader" text="Sparse Windows" /></Column>
                        <Column id="samplingSparseWaterCol"><Text id="samplingSparseWaterHeader" text="Sparse Water (L)" /></Column>
                    </columns>
                    <items>
                        <ColumnListItem id="samplingDataRow">
                            <cells>
                                <Text id="samplingStepCell" text="{day_label}" />
                                <Text id="samplingBaselineMoistureCell" text="{baseline_moisture}" />
                                <Text id="samplingSparseMoistureCell" text="{sparse_moisture}" />
                                <Text id="samplingRainCell" text="{rain_amount}" />
                                <Text id="samplingBaselineIrrigationCell" text="{baseline_irrigation_events}" />
                                <Text id="samplingSparseIrrigationCell" text="{sparse_irrigation_events}" />
                                <Text id="samplingSparseWaterCell" text="{sparse_water_usage_l}" />
                            </cells>
                        </ColumnListItem>
                    </items>
                </Table>
                        </IconTabFilter>
                        <IconTabFilter id="samplingPotsTab" text="Pots">
                            <Table id="samplingPotsTable" class="experimentDataTable" items="{/samplingPots}" growing="true" growingThreshold="20" growingScrollToLoad="false">
                                <columns>
                                    <Column id="samplingPotCodeCol"><Text id="samplingPotCodeHeader" text="Code" /></Column>
                                    <Column id="samplingPotLabelCol"><Text id="samplingPotLabelHeader" text="Pot" /></Column>
                                    <Column id="samplingPotSizeCol"><Text id="samplingPotSizeHeader" text="Size" /></Column>
                                    <Column id="samplingPotPlantCol"><Text id="samplingPotPlantHeader" text="Plant" /></Column>
                                    <Column id="samplingPotLocationCol"><Text id="samplingPotLocationHeader" text="Location" /></Column>
                                    <Column id="samplingPotSunCol"><Text id="samplingPotSunHeader" text="Sun" /></Column>
                                    <Column id="samplingPotFlowCol"><Text id="samplingPotFlowHeader" text="Flow ml/min" /></Column>
                                    <Column id="samplingPotTargetCol"><Text id="samplingPotTargetHeader" text="Target %" /></Column>
                                </columns>
                                <items>
                                    <ColumnListItem id="samplingPotRow">
                                        <cells>
                                            <Text id="samplingPotCodeCell" text="{pot_code}" />
                                            <Text id="samplingPotLabelCell" text="{label}" />
                                            <Text id="samplingPotSizeCell" text="{= ${small_subtype} ? ${size_class} + ' ' + ${small_subtype} : ${size_class}}" />
                                            <Text id="samplingPotPlantCell" text="{plant_type_label}" />
                                            <Text id="samplingPotLocationCell" text="{default_location}" />
                                            <Text id="samplingPotSunCell" text="{sun_exposure}" />
                                            <Text id="samplingPotFlowCell" text="{drip_flow_ml_min}" />
                                            <Text id="samplingPotTargetCell" text="{moisture_target_pct}" />
                                        </cells>
                                    </ColumnListItem>
                                </items>
                            </Table>
                        </IconTabFilter>
                    </items>
                </IconTabBar>
            </Panel>

            <Panel id="anfisPanel" headerText="ANFIS Intelligent Control" expandable="false" visible="{= ${/activeExperiment} === 'anfis'}" class="sapUiSmallMarginTop anfisPanel experimentPanel">
                <VBox class="busyWrapper" visible="{/isAnfisLoading}">
                    <BusyIndicator visible="{/isAnfisLoading}" text="Running ANFIS experiment..." />
                </VBox>
                <HBox id="anfisChartRow" class="chartWithOverviewRail">
                    <VBox id="anfisChartColumn" class="chartMainColumn">
                        <viz:VizFrame id="anfisChart" uiConfig="{applicationSet:'fiori'}" vizType="combination" height="500px" width="100%" renderComplete=".onChartRenderComplete">
                            <viz:dataset>
                                <viz.data:FlattenedDataset data="{/anfisChartEntries}">
                                    <viz.data:dimensions>
                                        <viz.data:DimensionDefinition name="Date/Time" value="{chart_label}" />
                                    </viz.data:dimensions>
                                    <viz.data:measures>
                                        <viz.data:MeasureDefinition name="Baseline Moisture" value="{baseline_moisture}" />
                                        <viz.data:MeasureDefinition name="Baseline Water Usage (L)" value="{baseline_water_usage_chart}" />
                                        <viz.data:MeasureDefinition name="ANFIS Moisture" value="{anfis_moisture}" />
                                        <viz.data:MeasureDefinition name="Predicted Probability" value="{predicted_probability_percent}" />
                                        <viz.data:MeasureDefinition name="ANFIS Water Usage (L)" value="{anfis_water_usage_chart}" />
                                        <viz.data:MeasureDefinition name="Max Temp (C)" value="{max_temperature}" />
                                        <viz.data:MeasureDefinition name="Rain (L/m2)" value="{rain_amount}" />
                                    </viz.data:measures>
                                </viz.data:FlattenedDataset>
                            </viz:dataset>
                            <viz:feeds>
                                <viz.feeds:FeedItem uid="valueAxis" type="Measure" values="Baseline Moisture,Baseline Water Usage (L),ANFIS Moisture,Predicted Probability,ANFIS Water Usage (L),Max Temp (C),Rain (L/m2)" />
                                <viz.feeds:FeedItem uid="categoryAxis" type="Dimension" values="Date/Time" />
                            </viz:feeds>
                        </viz:VizFrame>
                    </VBox>
                    <core:HTML id="anfisOverviewRail" content="{/overview/experimentSideRailHtml}" sanitizeContent="false" />
                </HBox>
                <IconTabBar id="anfisDataTabs" class="experimentDataTabs">
                    <items>
                        <IconTabFilter id="anfisExperimentDataTab" text="Experiment data">
                <Table id="anfisDataTable" class="experimentDataTable" items="{/anfisEntries}" growing="true" growingThreshold="20" growingScrollToLoad="false">
                    <headerToolbar>
                        <Toolbar id="anfisDataToolbar">
                            <Title id="anfisDataTitle" text="Experiment data" />
                        </Toolbar>
                    </headerToolbar>
                    <columns>
                        <Column id="anfisStepCol"><Text id="anfisStepHeader" text="Date" /></Column>
                        <Column id="anfisMoistureCol"><Text id="anfisMoistureHeader" text="ANFIS Moisture (%)" /></Column>
                        <Column id="anfisProbabilityCol"><Text id="anfisProbabilityHeader" text="Predicted Probability" /></Column>
                        <Column id="anfisCategoryCol"><Text id="anfisCategoryHeader" text="Category" /></Column>
                        <Column id="anfisBaselineIrrigationCol"><Text id="anfisBaselineIrrigationHeader" text="Baseline Windows" /></Column>
                        <Column id="anfisIrrigationCol"><Text id="anfisIrrigationHeader" text="ANFIS Windows" /></Column>
                        <Column id="anfisWaterCol"><Text id="anfisWaterHeader" text="ANFIS Water (L)" /></Column>
                    </columns>
                    <items>
                        <ColumnListItem id="anfisDataRow">
                            <cells>
                                <Text id="anfisStepCell" text="{day_label}" />
                                <Text id="anfisMoistureCell" text="{anfis_moisture}" />
                                <Text id="anfisProbabilityCell" text="{predicted_probability_percent}" />
                                <Text id="anfisCategoryCell" text="{predicted_category}" />
                                <Text id="anfisBaselineIrrigationCell" text="{baseline_irrigation_events}" />
                                <Text id="anfisIrrigationCell" text="{anfis_irrigation_events}" />
                                <Text id="anfisWaterCell" text="{anfis_water_usage_l}" />
                            </cells>
                        </ColumnListItem>
                    </items>
                </Table>
                        </IconTabFilter>
                        <IconTabFilter id="anfisPotsTab" text="Pots">
                            <Table id="anfisPotsTable" class="experimentDataTable" items="{/anfisPots}" growing="true" growingThreshold="20" growingScrollToLoad="false">
                                <columns>
                                    <Column id="anfisPotCodeCol"><Text id="anfisPotCodeHeader" text="Code" /></Column>
                                    <Column id="anfisPotLabelCol"><Text id="anfisPotLabelHeader" text="Pot" /></Column>
                                    <Column id="anfisPotSizeCol"><Text id="anfisPotSizeHeader" text="Size" /></Column>
                                    <Column id="anfisPotPlantCol"><Text id="anfisPotPlantHeader" text="Plant" /></Column>
                                    <Column id="anfisPotLocationCol"><Text id="anfisPotLocationHeader" text="Location" /></Column>
                                    <Column id="anfisPotSunCol"><Text id="anfisPotSunHeader" text="Sun" /></Column>
                                    <Column id="anfisPotFlowCol"><Text id="anfisPotFlowHeader" text="Flow ml/min" /></Column>
                                    <Column id="anfisPotTargetCol"><Text id="anfisPotTargetHeader" text="Target %" /></Column>
                                </columns>
                                <items>
                                    <ColumnListItem id="anfisPotRow">
                                        <cells>
                                            <Text id="anfisPotCodeCell" text="{pot_code}" />
                                            <Text id="anfisPotLabelCell" text="{label}" />
                                            <Text id="anfisPotSizeCell" text="{= ${small_subtype} ? ${size_class} + ' ' + ${small_subtype} : ${size_class}}" />
                                            <Text id="anfisPotPlantCell" text="{plant_type_label}" />
                                            <Text id="anfisPotLocationCell" text="{default_location}" />
                                            <Text id="anfisPotSunCell" text="{sun_exposure}" />
                                            <Text id="anfisPotFlowCell" text="{drip_flow_ml_min}" />
                                            <Text id="anfisPotTargetCell" text="{moisture_target_pct}" />
                                        </cells>
                                    </ColumnListItem>
                                </items>
                            </Table>
                        </IconTabFilter>
                    </items>
                </IconTabBar>
            </Panel>

            <Panel id="fuzzyPanel" headerText="Fuzzy DT Recommendation" expandable="false" visible="{= ${/activeExperiment} === 'fuzzy'}" class="sapUiSmallMarginTop fuzzyPanel experimentPanel">
                <VBox class="busyWrapper" visible="{/isFuzzyLoading}">
                    <BusyIndicator visible="{/isFuzzyLoading}" text="Running Fuzzy DT experiment..." />
                </VBox>
                <HBox id="fuzzyChartRow" class="chartWithOverviewRail">
                    <VBox id="fuzzyChartColumn" class="chartMainColumn">
                        <viz:VizFrame id="fuzzyChart" uiConfig="{applicationSet:'fiori'}" vizType="combination" height="500px" width="100%" renderComplete=".onChartRenderComplete">
                            <viz:dataset>
                                <viz.data:FlattenedDataset data="{/fuzzyChartEntries}">
                                    <viz.data:dimensions>
                                        <viz.data:DimensionDefinition name="Date/Time" value="{chart_label}" />
                                    </viz.data:dimensions>
                                    <viz.data:measures>
                                        <viz.data:MeasureDefinition name="Baseline Moisture" value="{baseline_moisture}" />
                                        <viz.data:MeasureDefinition name="Baseline Water Usage (L)" value="{baseline_water_usage_chart}" />
                                        <viz.data:MeasureDefinition name="Fuzzy Moisture" value="{fuzzy_moisture}" />
                                        <viz.data:MeasureDefinition name="Fuzzy Prescription (mm)" value="{fuzzy_prescription_mm}" />
                                        <viz.data:MeasureDefinition name="Fuzzy Water Usage (L)" value="{fuzzy_water_usage_chart}" />
                                        <viz.data:MeasureDefinition name="Max Temp (C)" value="{max_temperature}" />
                                        <viz.data:MeasureDefinition name="Rain (L/m2)" value="{rain_amount}" />
                                    </viz.data:measures>
                                </viz.data:FlattenedDataset>
                            </viz:dataset>
                            <viz:feeds>
                                <viz.feeds:FeedItem uid="valueAxis" type="Measure" values="Baseline Moisture,Baseline Water Usage (L),Fuzzy Moisture,Fuzzy Prescription (mm),Fuzzy Water Usage (L),Max Temp (C),Rain (L/m2)" />
                                <viz.feeds:FeedItem uid="categoryAxis" type="Dimension" values="Date/Time" />
                            </viz:feeds>
                        </viz:VizFrame>
                    </VBox>
                    <core:HTML id="fuzzyOverviewRail" content="{/overview/experimentSideRailHtml}" sanitizeContent="false" />
                </HBox>
                <IconTabBar id="fuzzyDataTabs" class="experimentDataTabs">
                    <items>
                        <IconTabFilter id="fuzzyExperimentDataTab" text="Experiment data">
                            <Table id="fuzzyDataTable" class="experimentDataTable" items="{/fuzzyEntries}" growing="true" growingThreshold="20" growingScrollToLoad="false">
                                <headerToolbar>
                                    <Toolbar id="fuzzyDataToolbar">
                                        <Title id="fuzzyDataTitle" text="Experiment data" />
                                    </Toolbar>
                                </headerToolbar>
                                <columns>
                                    <Column id="fuzzyStepCol"><Text id="fuzzyStepHeader" text="Date" /></Column>
                                    <Column id="fuzzyBaselineMoistureCol"><Text id="fuzzyBaselineMoistureHeader" text="Baseline Moisture (%)" /></Column>
                                    <Column id="fuzzyMoistureCol"><Text id="fuzzyMoistureHeader" text="Fuzzy Moisture (%)" /></Column>
                                    <Column id="fuzzyEtcCol"><Text id="fuzzyEtcHeader" text="ETc (mm)" /></Column>
                                    <Column id="fuzzyPrescriptionCol"><Text id="fuzzyPrescriptionHeader" text="Prescription (mm)" /></Column>
                                    <Column id="fuzzyRainCol"><Text id="fuzzyRainHeader" text="Rain (L/m2)" /></Column>
                                    <Column id="fuzzyEventsCol"><Text id="fuzzyEventsHeader" text="Fuzzy Windows" /></Column>
                                    <Column id="fuzzyWaterCol"><Text id="fuzzyWaterHeader" text="Fuzzy Water (L)" /></Column>
                                </columns>
                                <items>
                                    <ColumnListItem id="fuzzyDataRow">
                                        <cells>
                                            <Text id="fuzzyStepCell" text="{day_label}" />
                                            <Text id="fuzzyBaselineMoistureCell" text="{baseline_moisture}" />
                                            <Text id="fuzzyMoistureCell" text="{fuzzy_moisture}" />
                                            <Text id="fuzzyEtcCell" text="{etc_mm}" />
                                            <Text id="fuzzyPrescriptionCell" text="{fuzzy_prescription_mm}" />
                                            <Text id="fuzzyRainCell" text="{rain_amount}" />
                                            <Text id="fuzzyEventsCell" text="{fuzzy_irrigation_events}" />
                                            <Text id="fuzzyWaterCell" text="{fuzzy_water_usage_l}" />
                                        </cells>
                                    </ColumnListItem>
                                </items>
                            </Table>
                        </IconTabFilter>
                        <IconTabFilter id="fuzzyPotsTab" text="Pots">
                            <Table id="fuzzyPotsTable" class="experimentDataTable" items="{/fuzzyPots}" growing="true" growingThreshold="20" growingScrollToLoad="false">
                                <columns>
                                    <Column id="fuzzyPotCodeCol"><Text id="fuzzyPotCodeHeader" text="Code" /></Column>
                                    <Column id="fuzzyPotLabelCol"><Text id="fuzzyPotLabelHeader" text="Pot" /></Column>
                                    <Column id="fuzzyPotSizeCol"><Text id="fuzzyPotSizeHeader" text="Size" /></Column>
                                    <Column id="fuzzyPotPlantCol"><Text id="fuzzyPotPlantHeader" text="Plant" /></Column>
                                    <Column id="fuzzyPotLocationCol"><Text id="fuzzyPotLocationHeader" text="Location" /></Column>
                                    <Column id="fuzzyPotSunCol"><Text id="fuzzyPotSunHeader" text="Sun" /></Column>
                                    <Column id="fuzzyPotFlowCol"><Text id="fuzzyPotFlowHeader" text="Flow ml/min" /></Column>
                                    <Column id="fuzzyPotTargetCol"><Text id="fuzzyPotTargetHeader" text="Target %" /></Column>
                                </columns>
                                <items>
                                    <ColumnListItem id="fuzzyPotRow">
                                        <cells>
                                            <Text id="fuzzyPotCodeCell" text="{pot_code}" />
                                            <Text id="fuzzyPotLabelCell" text="{label}" />
                                            <Text id="fuzzyPotSizeCell" text="{= ${small_subtype} ? ${size_class} + ' ' + ${small_subtype} : ${size_class}}" />
                                            <Text id="fuzzyPotPlantCell" text="{plant_type_label}" />
                                            <Text id="fuzzyPotLocationCell" text="{default_location}" />
                                            <Text id="fuzzyPotSunCell" text="{sun_exposure}" />
                                            <Text id="fuzzyPotFlowCell" text="{drip_flow_ml_min}" />
                                            <Text id="fuzzyPotTargetCell" text="{moisture_target_pct}" />
                                        </cells>
                                    </ColumnListItem>
                                </items>
                            </Table>
                        </IconTabFilter>
                    </items>
                </IconTabBar>
            </Panel>
        </VBox>
        <footer>
            <Toolbar id="experimentFooterBar" class="experimentFooterBar">
                <HBox id="experimentFooterContent" width="100%" alignItems="Center" justifyContent="SpaceBetween" class="experimentFooterContent">
                    <HBox id="experimentFooterMeta" alignItems="Center" wrap="Wrap" class="experimentFooterMeta">
                        <HBox id="experimentFooterExperiment" alignItems="Center" class="experimentFooterItem">
                            <Text id="experimentFooterExperimentLabel" text="Experiment:" class="experimentFooterLabel" />
                            <Text id="experimentFooterExperimentValue" text="{/experimentFooter/experimentLabel}" class="experimentFooterValue" />
                        </HBox>
                        <HBox id="experimentFooterPeriod" alignItems="Center" class="experimentFooterItem">
                            <Text id="experimentFooterPeriodLabel" text="Period:" class="experimentFooterLabel" />
                            <Text id="experimentFooterPeriodValue" text="{= ${/experimentSettings/start_date} + ' to ' + ${/experimentSettings/end_date}}" class="experimentFooterValue" />
                        </HBox>
                        <HBox id="experimentFooterPots" alignItems="Center" class="experimentFooterItem">
                            <Text id="experimentFooterPotsLabel" text="Pots:" class="experimentFooterLabel" />
                            <Text id="experimentFooterPotsValue" text="{/experimentFooter/pots}" class="experimentFooterValue" />
                        </HBox>
                        <HBox id="experimentFooterDays" alignItems="Center" class="experimentFooterItem">
                            <Text id="experimentFooterDaysLabel" text="Days analyzed:" class="experimentFooterLabel" />
                            <Text id="experimentFooterDaysValue" text="{/experimentFooter/daysAnalyzed}" class="experimentFooterValue" />
                        </HBox>
                        <HBox id="experimentFooterInterval" alignItems="Center" class="experimentFooterItem">
                            <Text id="experimentFooterIntervalLabel" text="Time interval:" class="experimentFooterLabel" />
                            <Text id="experimentFooterIntervalValue" text="{/experimentFooter/timeInterval}" class="experimentFooterValue" />
                        </HBox>
                    </HBox>
                    <HBox id="experimentFooterCopyright" alignItems="Center" class="experimentFooterCopyright">
                        <Text id="experimentFooterCopyrightText" text="&#169; 2026 Smart Irrigation DT" class="experimentFooterValue" />
                        <Text id="experimentFooterSeparator" text="|" class="experimentFooterSeparator" />
                        <Text id="experimentFooterProductText" text="Digital Twin for Intelligent Irrigation" class="experimentFooterValue" />
                    </HBox>
                </HBox>
            </Toolbar>
        </footer>
    </Page>
</mvc:View>
