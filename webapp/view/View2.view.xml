<mvc:View controllerName="disertatie.controller.View2"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m">
    <Page id="page" title="Digital Twin Samples">
        <Text id="dtMessage" text="{/dtMessage}" />
        <Table id="dtTable1" items="{/dtData}">
            <headerToolbar>
                <Toolbar id="toolbar">
                    <Title id="title" text="Digital Twin Records" />
                </Toolbar>
            </headerToolbar>
            <columns>
                <Column id="col1"><Text id="t17" text="Timestamp"/></Column>
                <Column id="col2"><Text id="t18" text="Moisture"/></Column>
                <Column id="col3"><Text id="t19" text="Temperature"/></Column>
                <Column id="col4"><Text id="t20" text="Humidity"/></Column>
                <Column id="col5"><Text id="t21" text="Irrigation"/></Column>
            </columns>
            <items>
                <ColumnListItem id="cl1">
                    <cells>
                        <Text id="t22" text="{timestamp}" />
                        <Text id="t23" text="{moisture}" />
                        <Text id="t24" text="{temperature}" />
                        <Text id="t25" text="{humidity}" />
                        <Text text="{irrigation_active}" />
                    </cells>
                </ColumnListItem>
            </items>
        </Table>
    </Page>
</mvc:View>
